{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "incremental": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "jsx": "react-jsx",
    "jsxImportSource": "@bdui/dsl"
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx"],
  "exclude": [
    "**/dist/**",
    "**/node_modules/**",
    "**/generated/**",
    "**/__tests__/**",
    "packages/transpiler/src/__tests__/**"
  ]
}
