{
  "name": "@bdui/sdk",
  "version": "1.0.0",
  "description": "BDUI server integration SDK: programmatic registry client, compile helpers and Fastify/Express adapters",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client.js",
    "./express": "./dist/express.js",
    "./fastify": "./dist/fastify.js"
  },
  "typesVersions": {
    "*": {
      "client": [
        "dist/client.d.ts"
      ],
      "express": [
        "dist/express.d.ts"
      ],
      "fastify": [
        "dist/fastify.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bdui/core": "1.0.0",
    "@bdui/registry": "1.0.0",
    "@bdui/runtime": "1.0.0",
    "@bdui/schema": "1.0.0",
    "@bdui/transpiler": "1.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "private": false,
  "engines": {
    "node": ">=22"
  }
}
