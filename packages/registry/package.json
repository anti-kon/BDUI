{
  "name": "@bdui/registry",
  "version": "0.6.0",
  "description": "BDUI contract registry (HTTP API, pluggable storage, SemVer-aware resolve)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js",
    "./adapters/memory": "./dist/adapters/memory.js",
    "./adapters/fs": "./dist/adapters/fs.js"
  },
  "typesVersions": {
    "*": {
      "server": [
        "dist/server.d.ts"
      ],
      "adapters/memory": [
        "dist/adapters/memory.d.ts"
      ],
      "adapters/fs": [
        "dist/adapters/fs.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "private": false,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/bin.js",
    "dev": "node --watch dist/bin.js",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bdui/core": "file:../core",
    "@bdui/runtime": "file:../runtime",
    "@bdui/schema": "file:../schema",
    "@fastify/cors": "^10.0.2",
    "@fastify/etag": "^6.0.3",
    "fastify": "^5.2.1",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/semver": "^7.5.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
