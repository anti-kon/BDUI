{
  "name": "@bdui/transpiler",
  "version": "0.6.0-alpha.0",
  "description": "BDUI TSX → JSON transpiler (esbuild-based) with sourcemap-aware diagnostics",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bdui/core": "file:../core",
    "@bdui/schema": "file:../schema",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
