{
  "name": "taskly",
  "version": "0.1.0",
  "private": true,
  "description": "Операционный пульт — демо-приложение BDUI на базе @bdui/* пакетов.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build:contract": "node ../../packages/cli/dist/bin.js build src/app.tsx -o public/contract.json --mode prod",
    "build:client": "esbuild src/client.ts --bundle --format=esm --outfile=public/client.js --platform=browser --target=es2022 --sourcemap",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:contract && npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "dev": "npm run build && npm start",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bdui/core": "file:../../packages/core",
    "@bdui/defs": "file:../../packages/defs",
    "@bdui/dsl": "file:../../packages/dsl",
    "@bdui/expr": "file:../../packages/expr",
    "@bdui/renderer-web": "file:../../packages/renderer-web",
    "@bdui/runtime": "file:../../packages/runtime",
    "@bdui/sdk": "file:../../packages/sdk",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@bdui/cli": "file:../../packages/cli",
    "@bdui/registry": "file:../../packages/registry",
    "@bdui/schema": "file:../../packages/schema",
    "@bdui/transpiler": "file:../../packages/transpiler",
    "@types/node": "^24.13.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3"
  }
}
